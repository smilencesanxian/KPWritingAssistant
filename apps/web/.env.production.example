# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# LLM 配置（阿里云 DashScope）
LLM_API_KEY=your_dashscope_api_key
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen-plus

# OCR 提供商：baidu | tencent | claude
OCR_PROVIDER=baidu
BAIDU_OCR_API_KEY=your_baidu_ocr_api_key
BAIDU_OCR_SECRET_KEY=your_baidu_ocr_secret_key

# 腾讯云 OCR（OCR_PROVIDER=tencent 时填写）
# TENCENT_SECRET_ID=your_tencent_secret_id
# TENCENT_SECRET_KEY=your_tencent_secret_key

# Claude OCR（OCR_PROVIDER=claude 时填写）
# ANTHROPIC_API_KEY=your_anthropic_api_key
