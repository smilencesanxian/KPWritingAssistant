# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# LLM 配置（兼容 OpenAI 接口格式，可替换任意 OpenAI-compatible 提供商）
# 当前默认：阿里云 DashScope（通义千问）
# 切换 Kimi：LLM_BASE_URL=https://api.moonshot.cn/v1  LLM_MODEL=moonshot-v1-32k
# 切换 OpenAI：LLM_BASE_URL=https://api.openai.com/v1  LLM_MODEL=gpt-4o
# 切换 DeepSeek：LLM_BASE_URL=https://api.deepseek.com/v1  LLM_MODEL=deepseek-chat
LLM_API_KEY=your_dashscope_api_key
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen-plus

# OCR 提供商配置：baidu | tencent | claude（默认 baidu）
OCR_PROVIDER=baidu

# Baidu OCR - https://ai.baidu.com/tech/ocr
BAIDU_OCR_API_KEY=your_baidu_ocr_api_key
BAIDU_OCR_SECRET_KEY=your_baidu_ocr_secret_key

# Tencent Cloud OCR - https://console.cloud.tencent.com/ocr
# 在访问管理 -> API密钥管理中创建：https://console.cloud.tencent.com/cam/capi
TENCENT_SECRET_ID=your_tencent_secret_id
TENCENT_SECRET_KEY=your_tencent_secret_key

# Claude OCR - https://console.anthropic.com/
# OCR_PROVIDER=claude 时使用，需要填写 Anthropic API Key
ANTHROPIC_API_KEY=your_anthropic_api_key
